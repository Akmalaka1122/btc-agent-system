# ============================================
# BTC Agent System — Configuration
# ============================================
# Copy ke .env dan isi manual sebelum start:
#   cp .env.example .env
# ============================================

# --- LLM Provider (OpenAI-compatible) ---
# Pilih salah satu provider, uncomment yang dipakai:

# Option 1: Xpiki (Claude Opus 4.8)
LLM_BASE_URL=https://api.xpiki.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=kr/claude-opus-4.8

# Option 2: UniModel (GLM-5.2, free)
# LLM_BASE_URL=https://www.unimodel.ai/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=glm-5.2

# Option 3: Conduit (Claude Opus 4.8)
# LLM_BASE_URL=https://conduit.ozdoev.net/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=claude-opus-4-8

# Option 4: AnyRouter (DeepSeek V3.2, free)
# LLM_BASE_URL=https://anyrouter.dev/api/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=deepseek/deepseek-v3.2

# Option 5: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=gpt-4o

# Option 6: OpenRouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=anthropic/claude-sonnet-4

# LLM tuning
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
TELEGRAM_ADMIN_IDS=your-telegram-user-id

# --- Polymarket (isi saat mau live trading) ---
POLYMARKET_PRIVATE_KEY=your-polygon-wallet-private-key
POLYMARKET_DEPOSIT_WALLET=your-deposit-wallet-address
POLYMARKET_API_KEY=your-polymarket-api-key
POLYMARKET_API_SECRET=your-polymarket-api-secret

# --- Binance (for BTC price data) ---
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# --- System ---
CYCLE_INTERVAL_SECONDS=300
MAX_RISK_PCT_PER_TRADE=2
PAPER_TRADING=true
