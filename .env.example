# ============================================
# BTC Agent System — Configuration
# ============================================
# Copy ke .env dan isi manual sebelum start:
#   cp .env.example .env
# ============================================

# --- LLM Provider ---
# Pilih salah satu provider, uncomment yang dipakai:

# === Option 1: OpenRouter (multi-model gateway) ===
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-...your-key
# Models: anthropic/claude-sonnet-4, deepseek/deepseek-r1, openai/gpt-4o, xiaomi/mimo-v2.5
LLM_MODEL=anthropic/claude-sonnet-4

# === Option 2: Xiaomi MiMo ===
# LLM_PROVIDER=xiaomi
# LLM_BASE_URL=https://api.xiaomi.com/v1
# LLM_API_KEY=your-xiaomi-key
# LLM_MODEL=mimo-v2.5

# === Option 3: DeepSeek ===
# LLM_PROVIDER=deepseek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-...your-key
# LLM_MODEL=deepseek-chat
# Alternatif: deepseek-reasoner (R1)

# === Option 4: Anthropic (native SDK) ===
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_KEY=sk-ant-...your-key
# LLM_MODEL=claude-sonnet-4-20250514
# Alternatif: claude-opus-4-20250514

# === Option 5: OpenAI ===
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...your-key
# LLM_MODEL=gpt-4o
# Alternatif: gpt-4o-mini, o3-mini

# === Bonus: Xpiki (Claude via proxy) ===
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.xpiki.com/v1
# LLM_API_KEY=sk-...your-key
# LLM_MODEL=kr/claude-opus-4.8

# === Bonus: Conduit (Claude via proxy) ===
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://conduit.ozdoev.net/v1
# LLM_API_KEY=your-conduit-key
# LLM_MODEL=claude-opus-4-8

# LLM tuning
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ADMIN_IDS=your-telegram-user-id

# --- Polymarket (isi saat mau live trading) ---
POLYMARKET_PRIVATE_KEY=your-polygon-wallet-private-key
POLYMARKET_DEPOSIT_WALLET=your-deposit-wallet-address
POLYMARKET_API_KEY=your-polymarket-api-key
POLYMARKET_API_SECRET=your-polymarket-api-secret

# --- Binance (for BTC price data) ---
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# --- System ---
CYCLE_INTERVAL_SECONDS=300
MAX_RISK_PCT_PER_TRADE=2
PAPER_TRADING=true
