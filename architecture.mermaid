flowchart TB
    subgraph EXT["External Data Sources"]
        BIN[Binance/Coinbase API]
        SOC[Twitter/Reddit + Funding/OI/Liquidations]
        POLY[Polymarket odds/liquidity]
    end

    subgraph CORE["Orchestrator Core - Python asyncio"]
        ORC[Orchestrator / Hale<br/>Linear pipeline, no parallel wave needed]
        SCHED[Scheduler<br/>triggers every 5-min window]
    end

    A1[1. Market & Sentiment Analyst<br/>price + orderbook + funding/OI + fast-filter news/onchain]
    A2[2. Research Agent<br/>internal bull/bear synthesis]
    A3[3. Trader Agent<br/>EV check + entry timing]
    A4[4. Risk & Portfolio Manager<br/>3-lens sizing + final call, 2% hard cap]

    subgraph OUT["Output Layer"]
        DB[(SQLite/Postgres<br/>cycle logs)]
        TG[Telegram Bot]
        EXEC[Execution Module<br/>manual-confirm only]
    end

    subgraph TGUSERS["Telegram"]
        USER1[Alerts to chat/group]
        CMD["/status /history /run /pause /resume"]
    end

    SCHED --> ORC
    BIN --> A1
    SOC --> A1
    ORC --> A1
    A1 -->|verified MarketReport| ORC
    ORC --> A2
    A2 -->|verified ResearchPlan| ORC
    ORC --> A3
    POLY --> A3
    A3 -->|verified TraderProposal| ORC
    ORC --> A4
    A4 -->|verified PortfolioDecision| ORC
    ORC --> DB
    ORC --> TG
    DB --> TG
    TG --> USER1
    CMD --> ORC
    A4 -.optional manual confirm.-> EXEC
    EXEC -.-> POLY

    style ORC fill:#c0392b,color:#fff
    style A4 fill:#c0392b,color:#fff
    style TG fill:#2980b9,color:#fff
    style DB fill:#7f8c8d,color:#fff
